---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import MenuCard from '../components/MenuCard.astro';
import ContactInfo from '../components/ContactInfo.astro';
import { STORE_INFO, MENU_ITEMS } from '../utils/constants';
---

<Layout>
  <fragment slot="header"><Header /></fragment>

  <!-- Hero Section -->
  <Hero />

  <!-- Featured Menu Section -->
  <section class="py-16 md:py-24 bg-background">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-primary font-medium text-sm tracking-wider uppercase mb-2">Our Specialties</p>
        <h2 class="text-3xl md:text-4xl font-bold font-heading text-text-primary mb-4">招牌推薦</h2>
        <p class="text-text-secondary max-w-2xl mx-auto">
          兩大粵式豬腳經典做法，一店雙享，為您呈現最道地的廣東風味
        </p>
      </div>

      <div class="space-y-16 md:space-y-24">
        {MENU_ITEMS.map((item, i) => (
          <MenuCard {...item} reversed={i % 2 !== 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- Brand Story Teaser -->
  <section class="py-16 md:py-24 bg-background-alt">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-secondary/20 to-primary/10 flex items-center justify-center">
            <div class="text-center p-8">
              <span class="text-7xl">🏘️</span>
              <p class="text-text-secondary text-sm mt-4">小榄美食文化</p>
            </div>
          </div>
        </div>
        <div>
          <p class="text-primary font-medium text-sm tracking-wider uppercase mb-2">Our Story</p>
          <h2 class="text-3xl md:text-4xl font-bold font-heading text-text-primary mb-6">立足小榄 · 傳承粵味</h2>
          <p class="text-text-secondary leading-relaxed mb-4">
            <strong class="text-text-primary">{STORE_INFO.name}</strong> 位於美食重鎮——廣東省中山市小榄鎮。
            小榄以菊花宴等傳統飲食文化聞名，我們在此扎根，將沙薑豬腳與豬腳薑兩大經典粵式美味帶給每一位食客。
          </p>
          <p class="text-text-secondary leading-relaxed mb-6">
            從「焯水 → 燉煮 → 冰水浸泡」的匠心工序，到瓦煲中甜醋與老薑的慢火交融，
            每一道菜都承載著對傳統粵式美食的堅持與熱愛。
          </p>
          <a
            href="/about"
            class="inline-flex items-center gap-2 text-primary hover:text-primary-dark font-medium transition-colors"
          >
            了解更多
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact / Map Section -->
  <section class="py-16 md:py-24 bg-background">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold font-heading text-text-primary mb-4">找到我們</h2>
        <p class="text-text-secondary max-w-2xl mx-auto">歡迎來店品嚐，感受最道地的粵式豬腳美味</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Map -->
        <div class="rounded-2xl overflow-hidden shadow-lg border border-background-alt aspect-[4/3] lg:aspect-auto">
          <iframe
            class="w-full h-full min-h-[300px]"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=${encodeURIComponent(STORE_INFO.mapQuery)}`}
            title="店家位置"
            allowfullscreen
          ></iframe>
        </div>

        <!-- Contact Info -->
        <ContactInfo />
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-primary hover:bg-primary-dark text-text-primary font-bold rounded-full transition-all shadow-lg hover:shadow-xl"
        >
          聯絡我們
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <fragment slot="footer"><Footer /></fragment>
</Layout>
