---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactInfo from '../components/ContactInfo.astro';
import { STORE_INFO } from '../utils/constants';
---

<Layout title="联络我们" description="联络虾姑猪脚姜：地址位于广东省中山市小榄镇东升同乐路33号，电话18688647083，周一至周日08:00-21:00营业。">
  <fragment slot="header"><Header /></fragment>

  <!-- Page Header -->
  <section class="relative py-20 md:py-28 bg-gradient-to-br from-text-primary via-secondary-dark to-text-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 50% 50%, #B22222 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-black font-heading text-white text-shadow-lg mb-4">联络我们</h1>
      <p class="text-lg text-background-alt/80">欢迎来电预订或到店品尝</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 md:py-20 bg-background">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Left: Contact Info -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold font-heading text-text-primary mb-6">店家资讯</h2>
          <ContactInfo />

          <!-- Social -->
          <div class="mt-8">
            <h3 class="text-lg font-bold font-heading text-text-primary mb-4">追踪我们</h3>
            <div class="flex items-center gap-4">
              <a href={STORE_INFO.instagram} class="w-12 h-12 rounded-full bg-background-alt flex items-center justify-center hover:bg-primary/20 transition-colors" aria-label="Instagram">
                <svg class="w-6 h-6 text-text-secondary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href={STORE_INFO.xiaohongshu} class="w-12 h-12 rounded-full bg-background-alt flex items-center justify-center hover:bg-accent/20 transition-colors" aria-label="小红书">
                <svg class="w-6 h-6 text-text-secondary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold font-heading text-text-primary mb-6">给我们留言</h2>
          <div class="bg-white rounded-2xl shadow-lg border border-background-alt p-6 sm:p-8">
            <form id="contact-form" class="space-y-5" method="POST">
              <div>
                <label for="name" class="block text-sm font-medium text-text-primary mb-1.5">姓名 *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-2.5 border border-background-alt rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-background text-text-primary"
                  placeholder="您的姓名"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-text-primary mb-1.5">电话 *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-2.5 border border-background-alt rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-background text-text-primary"
                  placeholder="您的联络电话"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-text-primary mb-1.5">留言内容 *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-2.5 border border-background-alt rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-background text-text-primary resize-none"
                  placeholder="请告诉我们您的需求或疑问..."
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full px-6 py-3 bg-primary hover:bg-primary-dark text-text-primary font-bold rounded-full transition-all shadow-md hover:shadow-lg"
              >
                送出留言
              </button>
            </form>

            <!-- Success Message -->
            <div id="form-success" class="hidden text-center py-8">
              <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-text-primary mb-2">感谢您的留言！</h3>
              <p class="text-text-secondary">我们会尽快与您联系。您也可以直接致电 {STORE_INFO.phoneDisplay}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="pb-16 bg-background">
  <!-- Map -->
  <div class="rounded-2xl overflow-hidden shadow-lg border border-background-alt aspect-[4/3] lg:aspect-auto">
	<iframe
	class="w-full h-full min-h-[300px]"
	loading="lazy"
	referrerpolicy="no-referrer-when-downgrade"
	src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=${encodeURIComponent(STORE_INFO.mapQuery)}`}
	title="店家位置"
	allowfullscreen
	></iframe>
  </div>
  </section>

  <fragment slot="footer"><Footer /></fragment>

  <script>
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (res.ok) {
            form.classList.add('hidden');
            success.classList.remove('hidden');
          } else {
            alert('提交失败，请稍后再试或直接来电。');
          }
        } catch {
          alert('网路错误，请检查连线后再试。');
        }
      });
    }
  </script>
</Layout>
