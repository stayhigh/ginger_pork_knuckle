---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { STORE_INFO } from '../utils/constants';
---

<Layout title="页面未找到" description="抱歉，您访问的页面不存在。">
  <fragment slot="header"><Header /></fragment>

  <section class="flex-1 flex items-center justify-center py-20 bg-background">
    <div class="text-center max-w-lg mx-auto px-4">
      <span class="text-8xl block mb-6" aria-hidden="true">🍖</span>
      <h1 class="text-5xl md:text-6xl font-black font-heading text-text-primary mb-4">404</h1>
      <p class="text-xl text-text-secondary mb-2">页面未找到</p>
      <p class="text-text-secondary/70 mb-8">
        抱歉，您访问的页面不存在。可能已被移除或连结有误。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-8 py-3 bg-primary hover:bg-primary-dark text-text-primary font-bold rounded-full transition-all shadow-lg">
          返回首页
        </a>
        <a href={`tel:${STORE_INFO.phone}`} class="px-8 py-3 bg-accent hover:bg-accent-dark text-white font-bold rounded-full transition-all shadow-lg">
          拨打电话 {STORE_INFO.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <fragment slot="footer"><Footer /></fragment>
</Layout>
