---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { STORE_INFO } from '../utils/constants';
---

<Layout title="美食文化" description="探索沙姜猪脚的粤菜起源与发展、猪脚姜从产妇补品到街头美食的文化演变，以及小榄镇的饮食文化传统。">
  <fragment slot="header"><Header /></fragment>

  <!-- Page Header -->
  <section class="relative py-20 md:py-28 bg-gradient-to-br from-text-primary to-secondary-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 75%, #D4A04A 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-black font-heading text-white text-shadow-lg mb-4">美食文化</h1>
      <p class="text-lg text-background-alt/80">探索粤式猪脚背后的文化底蕴</p>
    </div>
  </section>

  <!-- Article 1: Sha Jiang Pig Foot Origins -->
  <section class="py-16 md:py-20 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-10">
        <div class="order-2 md:order-1">
          <p class="text-primary font-medium text-sm tracking-wider mb-1">粤菜起源</p>
          <h2 class="text-3xl md:text-4xl font-bold font-heading text-text-primary mb-6">沙姜猪脚的粤菜起源与发展</h2>
          <div class="prose prose-stone max-w-none text-text-secondary leading-relaxed space-y-4">
            <p>
              沙姜，又称山奈、三奈，是一种源自东南亚的多年生草本植物的根茎，
              早在宋代就已传入中国南方，并在粤菜中发扬光大。其独特的辛香气味，
              与姜相似但更为温和，带有淡淡的樟脑香气，是粤式卤水和凉拌菜肴的灵魂调料之一。
            </p>
            <p>
              沙姜猪脚作为一道经典的粤式凉菜，历史悠久。在广东的传统饮食文化中，
              猪脚因富含胶质而被视为美容养颜的食材，与沙姜的辛香结合后，
              不仅去除了猪脚可能带有的油腻感，更让整体风味提升到新的层次。
            </p>
            <p>
              时至今日，沙姜猪脚已从传统的粤式酒楼走向街头巷尾，
              成为广东人日常餐桌上的家常菜，也深受外地游客的喜爱。
              其清爽Q弹的口感，特别适合在炎热的夏季食用，是粤式饮食文化中「因时制宜」的绝佳体现。
            </p>
          </div>
        </div>
        <div class="order-1 md:order-2 aspect-[4/3] rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/menu/sha-jiang-pig-foot.jpg" alt="沙姜（山奈）" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Article 2: Ginger Vinegar Pig Foot Evolution -->
  <section class="py-16 md:py-20 bg-background-alt">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-10">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/menu/ginger-vinegar-pig-foot.jpg" alt="传统补品" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div>
          <p class="text-primary font-medium text-sm tracking-wider mb-1">文化演变</p>
          <h2 class="text-3xl md:text-4xl font-bold font-heading text-text-primary mb-6">猪脚姜：从产妇补品到街头美食</h2>
          <div class="prose prose-stone max-w-none text-text-secondary leading-relaxed space-y-4">
            <p>
              在粤式传统中，猪脚姜是一道充满温情与智慧的滋补美食。
              它的起源可追溯到广东民间「坐月」习俗——产妇生产后，家人会以老姜、
              甜醋与猪脚慢火熬煮，认为这道菜有驱风散寒、活血化瘀、补充胶质之效，
              帮助产妇恢复体力与促进乳汁分泌。
            </p>
            <p>
              随著时代的演变，猪脚姜早已超越了产妇补品的定位。
              它独特的甜辣风味与丰富的胶质口感，让它成为广东人冬季暖身的街头美食。
              在香港、广州、中山等地的街头巷尾，不难发现售卖猪脚姜的小摊，
              一碗热腾腾的猪脚姜配上白饭或面条，就是最朴实而满足的一餐。
            </p>
            <p>
              猪脚姜也承载著广东人「药食同源」的饮食哲学——将食材的滋补功效与美味完美结合，
              这正是粤式饮食文化深入人心的核心魅力所在。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article 3: XiaoLan Culinary Tradition -->
  <section class="py-16 md:py-20 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-10">
        <div>
          <p class="text-primary font-medium text-sm tracking-wider mb-1">在地连结</p>
          <h2 class="text-3xl md:text-4xl font-bold font-heading text-text-primary mb-6">小榄镇的饮食文化传统</h2>
          <div class="prose prose-stone max-w-none text-text-secondary leading-relaxed space-y-4">
            <p>
              小榄镇，位于珠江三角洲腹地，是广东省中山市的重要组成部分。
              这座拥有八百多年历史的古镇，以「菊花文化」闻名遐迩。
              每年秋季举办的小榄菊花会，是国家级非物质文化遗产，
              吸引来自世界各地的游客前来观赏。
            </p>
            <p>
              小榄的饮食文化同样丰富多彩。菊花宴是最具代表性的美食盛事——
              以新鲜菊花入馔，创作出菊花鱼球、菊花肉、菊花糕等数十道精致菜肴，
              展现了小榄人对食材的深刻理解与烹调智慧。
            </p>
            <p>
              在这片饮食文化的沃土上，<strong class="text-text-primary">{STORE_INFO.name}</strong> 
              以粤式猪脚专家的身份，为小榄的美食版图增添独特风味。
              我们将沙姜猪脚的清爽与猪脚姜的温润带给每一位食客，
              延续这座古镇对美食的坚持与热爱。
            </p>
          </div>
        </div>
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/gallery/asian-food-platter.jpg" alt="小榄菊花会" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Wisdom Section -->
  <section class="py-16 bg-background-alt">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold font-heading text-text-primary mb-4">药食同源 · 粤式智慧</h2>
        <p class="text-text-secondary">一碗猪脚里蕴含的养生哲学</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-md border border-background-alt">
          <h3 class="font-bold font-heading text-text-primary mb-2 flex items-center gap-2">
            <span class="text-xl">🌡️</span> 沙姜 — 温中散寒
          </h3>
          <p class="text-sm text-text-secondary">沙姜性温，具有温中散寒、行气止痛的功效，特别适合食欲不振、消化不良者食用。</p>
          <div class="aspect-[3/1] mt-4 rounded-lg bg-gradient-to-r from-primary/10 to-background-alt flex items-center justify-center">
            <span class="text-xs text-text-secondary">图片来源：Pixabay</span>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md border border-background-alt">
          <h3 class="font-bold font-heading text-text-primary mb-2 flex items-center gap-2">
            <span class="text-xl">❤️</span> 甜醋 — 活血养颜
          </h3>
          <p class="text-sm text-text-secondary">甜醋以糯米发酵而成，富含氨基酸与矿物质，有助促进血液循环、美容养颜。</p>
          <div class="aspect-[3/1] mt-4 rounded-lg bg-gradient-to-r from-accent/5 to-secondary/10 flex items-center justify-center">
            <span class="text-xs text-text-secondary">图片来源：Pixabay</span>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md border border-background-alt">
          <h3 class="font-bold font-heading text-text-primary mb-2 flex items-center gap-2">
            <span class="text-xl">🦴</span> 猪脚 — 胶质丰富
          </h3>
          <p class="text-sm text-text-secondary">猪脚富含胶原蛋白与钙质，有助于保持皮肤弹性、强健骨骼，是天然的美容食材。</p>
          <div class="aspect-[3/1] mt-4 rounded-lg bg-gradient-to-r from-secondary/10 to-background-alt flex items-center justify-center">
            <span class="text-xs text-text-secondary">图片来源：FoodiesFeed</span>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md border border-background-alt">
          <h3 class="font-bold font-heading text-text-primary mb-2 flex items-center gap-2">
            <span class="text-xl">🥚</span> 鸡蛋 — 营养全面
          </h3>
          <p class="text-sm text-text-secondary">猪脚姜中的鸡蛋经过长时间焖煮，充分吸收甜醋精华，蛋白质丰富，是营养与美味的结合。</p>
          <div class="aspect-[3/1] mt-4 rounded-lg bg-gradient-to-r from-primary/5 to-background-alt flex items-center justify-center">
            <span class="text-xs text-text-secondary">图片来源：Pixabay</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <fragment slot="footer"><Footer /></fragment>
</Layout>
