---
import { STORE_INFO } from '../utils/constants';
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <img
    src="/images/hero/hero-pig-foot-01.jpg"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    aria-hidden="true"
  />
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-text-primary/85 to-secondary-dark/85"></div>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, #D4A04A 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Floating Icon -->
    <div class="animate-float mb-6">
      <span class="text-7xl md:text-8xl inline-block" aria-hidden="true">🍖</span>
    </div>

    <!-- Tagline -->
    <p class="text-primary-light font-medium text-lg md:text-xl mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
      {STORE_INFO.tagline}
    </p>

    <!-- Title -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black font-heading text-white text-shadow-lg mb-6 animate-fade-in-up" style="animation-delay: 0.2s;">
      {STORE_INFO.name}
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl md:text-2xl text-background-alt/90 max-w-2xl mx-auto mb-10 animate-fade-in-up" style="animation-delay: 0.3s;">
      <span class="inline-block border-r border-background-alt/40 pr-4 mr-4">沙姜猪脚 · 咸香Q弹</span>
      <span class="inline-block">猪脚姜 · 甜辣暖胃</span>
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.4s;">
      <a
        href="/menu"
        class="px-8 py-3.5 bg-primary hover:bg-primary-dark text-text-primary font-bold rounded-full transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        查看菜单
      </a>
      <a
        href={`tel:${STORE_INFO.phone}`}
        class="px-8 py-3.5 bg-accent hover:bg-accent-dark text-white font-bold rounded-full transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 flex items-center gap-2"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        拨打电话
      </a>
    </div>

    <!-- Quick Info Bar -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.5s;">
      <div class="bg-white/10 backdrop-blur-sm rounded-xl px-4 py-3">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="text-sm text-white/90">{STORE_INFO.address}</span>
        </div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl px-4 py-3">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm text-white/90">{STORE_INFO.hours}</span>
        </div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl px-4 py-3">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href={`tel:${STORE_INFO.phone}`} class="text-sm text-white/90 hover:text-primary transition-colors">
            {STORE_INFO.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
