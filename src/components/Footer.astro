---
import { STORE_INFO } from '../utils/constants';
---

<footer class="bg-text-primary text-background">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-3xl" aria-hidden="true">🍖</span>
          <div>
            <h3 class="text-xl font-bold font-heading">{STORE_INFO.name}</h3>
            <p class="text-sm text-background-alt/70">正宗粤式 · 一店双味</p>
          </div>
        </div>
        <p class="text-sm text-background-alt/80 leading-relaxed">
          位于广东省中山市小榄镇，以沙姜猪脚与猪脚姜两大粤式猪脚经典做法，为您呈现最地道的粤式风味。
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold font-heading mb-4">快速连结</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-background-alt/80 hover:text-primary transition-colors">首页</a></li>
          <li><a href="/about" class="text-sm text-background-alt/80 hover:text-primary transition-colors">关于我们</a></li>
          <li><a href="/menu" class="text-sm text-background-alt/80 hover:text-primary transition-colors">菜单介绍</a></li>
          <li><a href="/culture" class="text-sm text-background-alt/80 hover:text-primary transition-colors">美食文化</a></li>
          <li><a href="/contact" class="text-sm text-background-alt/80 hover:text-primary transition-colors">联络我们</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-lg font-bold font-heading mb-4">联络资讯</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-1 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-sm text-background-alt/80">{STORE_INFO.address}</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href={`tel:${STORE_INFO.phone}`} class="text-sm text-background-alt/80 hover:text-primary transition-colors">
              {STORE_INFO.phoneDisplay}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm text-background-alt/80">{STORE_INFO.hours}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 pt-8 border-t border-background-alt/20">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-background-alt/60">
          &copy; {new Date().getFullYear()} {STORE_INFO.name}. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <span class="text-xs text-background-alt/60">追踪我们</span>
          <a href={STORE_INFO.instagram} class="text-background-alt/60 hover:text-primary transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={STORE_INFO.xiaohongshu} class="text-background-alt/60 hover:text-primary transition-colors" aria-label="小红书">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
